# Use an official public Azure endpoint. AZURE_OPENAI_ENDPOINT takes precedence.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_AI_PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project

# Azure deployment names, not base model IDs. Remove lines for models you did not deploy.
GPT_41_DEPLOYMENT_NAME=gpt-4.1
GPT_4O_DEPLOYMENT_NAME=gpt-4o
GPT_51_DEPLOYMENT_NAME=gpt-5.1
GPT_52_DEPLOYMENT_NAME=gpt-5.2
GPT_54_DEPLOYMENT_NAME=gpt-5.4
GPT_54_MINI_DEPLOYMENT_NAME=gpt-5.4-mini
GPT_54_NANO_DEPLOYMENT_NAME=gpt-5.4-nano
GPT_56_SOL_DEPLOYMENT_NAME=gpt-5.6-sol
GPT_56_TERRA_DEPLOYMENT_NAME=gpt-5.6-terra
GPT_56_LUNA_DEPLOYMENT_NAME=gpt-5.6-luna

# Optional. Unset to use every effort supported by each configured GPT-5.x model.
REASONING_EFFORTS=max,xhigh,high,medium,low,none
# GPT-4.x Chat Completions uses max_tokens; GPT-5.x Responses uses max_output_tokens.
MAX_OUTPUT_TOKENS=4096
REQUEST_TIMEOUT_SECONDS=120
MAX_RETRIES=0
AZURE_OPENAI_TOKEN_SCOPE=https://ai.azure.com/.default
